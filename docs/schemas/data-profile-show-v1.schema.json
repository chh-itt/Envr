{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/envr-workspace/envr/blob/main/docs/schemas/data-profile-show-v1.schema.json",
  "title": "envr profile show (message: profile_show)",
  "type": "object",
  "additionalProperties": true,
  "required": ["config_dir", "name", "runtimes", "env"],
  "properties": {
    "config_dir": { "type": "string" },
    "name": { "type": "string" },
    "runtimes": {
      "type": "object",
      "description": "Profile runtime pins (serde shape from ProjectConfig profiles)"
    },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
