{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/envr-workspace/envr/blob/main/docs/schemas/data-cache-index-status-v1.schema.json",
  "title": "envr cache index status (message: cache_index_status)",
  "type": "object",
  "additionalProperties": true,
  "required": ["dir", "entries"],
  "properties": {
    "dir": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["runtime", "files", "newest_mtime_unix_secs"],
        "properties": {
          "runtime": { "type": "string" },
          "files": { "type": "integer", "minimum": 0 },
          "newest_mtime_unix_secs": {
            "oneOf": [{ "type": "integer" }, { "type": "null" }]
          }
        }
      }
    }
  }
}
