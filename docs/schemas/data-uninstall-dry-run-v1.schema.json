{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/envr-workspace/envr/blob/main/docs/schemas/data-uninstall-dry-run-v1.schema.json",
  "title": "envr uninstall --dry-run (success or validation refusal)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "kind",
    "version",
    "would_refuse_active_without_force",
    "paths",
    "external_command"
  ],
  "properties": {
    "kind": { "type": "string" },
    "version": { "type": "string" },
    "would_refuse_active_without_force": { "type": "boolean" },
    "paths": { "type": "array", "items": { "type": "string" } },
    "external_command": {
      "oneOf": [{ "type": "string" }, { "type": "null" }]
    }
  }
}
