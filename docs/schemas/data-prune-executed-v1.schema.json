{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/envr-workspace/envr/blob/main/docs/schemas/data-prune-executed-v1.schema.json",
  "title": "envr prune --execute (message: prune_executed)",
  "type": "object",
  "additionalProperties": true,
  "required": ["removed"],
  "properties": {
    "removed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "version"],
        "properties": {
          "kind": { "type": "string" },
          "version": { "type": "string" }
        }
      }
    }
  }
}
