{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/envr-workspace/envr/blob/main/docs/schemas/data-config-keys-v1.schema.json",
  "title": "envr config keys (message: config_keys)",
  "type": "object",
  "additionalProperties": true,
  "required": ["path", "keys", "migrated"],
  "properties": {
    "path": { "type": "string" },
    "keys": { "type": "array", "items": { "type": "string" } },
    "migrated": { "type": "boolean" }
  }
}
