{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/envr-workspace/envr/blob/main/docs/schemas/data-prune-dry-run-v1.schema.json",
  "title": "envr prune dry-run (message: prune_dry_run)",
  "type": "object",
  "additionalProperties": true,
  "required": ["dry_run", "plan"],
  "properties": {
    "dry_run": { "const": true },
    "plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "would_remove"],
        "properties": {
          "kind": { "type": "string" },
          "would_remove": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
