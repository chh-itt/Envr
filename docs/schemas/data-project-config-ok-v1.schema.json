{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/envr-workspace/envr/blob/main/docs/schemas/data-project-config-ok-v1.schema.json",
  "title": "envr check success (message: project_config_ok)",
  "type": "object",
  "additionalProperties": true,
  "required": ["config_dir", "pinned_runtimes"],
  "properties": {
    "config_dir": { "type": "string" },
    "base_file": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
    "local_file": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
    "pinned_runtimes": { "type": "integer", "minimum": 0 }
  }
}
