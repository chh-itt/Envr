{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/envr-workspace/envr/blob/main/docs/schemas/data-project-env-v1.schema.json",
  "title": "envr env (message: project_env)",
  "type": "object",
  "additionalProperties": true,
  "required": ["shell", "vars"],
  "properties": {
    "shell": {
      "type": "string",
      "enum": ["posix", "cmd", "powershell"]
    },
    "vars": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
