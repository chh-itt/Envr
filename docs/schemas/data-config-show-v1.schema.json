{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/envr-workspace/envr/blob/main/docs/schemas/data-config-show-v1.schema.json",
  "title": "envr config show (message: config_show)",
  "type": "object",
  "additionalProperties": true,
  "required": ["path", "settings", "migrated"],
  "properties": {
    "path": { "type": "string" },
    "settings": {
      "type": "object",
      "description": "Merged Settings struct as JSON (shape may evolve; treat as opaque or validate separately)."
    },
    "migrated": { "type": "boolean" }
  }
}
