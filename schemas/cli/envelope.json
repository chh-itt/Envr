{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://envr.dev/schemas/cli/envelope.json",
  "title": "envr CLI JSON envelope (stdout, one object per line)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "success",
    "code",
    "message",
    "data",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 3,
      "description": "Current CLI contract is v3. v3 makes envelope `code` required and stable for both success and failure; automation must not rely on `message`."
    },
    "success": { "type": "boolean" },
    "code": { "type": "string" },
    "message": { "type": "string" },
    "data": {
      "description": "Command-specific payload; see schemas/cli/data/*.json"
    },
    "diagnostics": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
