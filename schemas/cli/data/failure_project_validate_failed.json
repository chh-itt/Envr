{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://envr.dev/schemas/cli/data/failure_project_validate_failed.json",
  "title": "project validate failed envelope.data (code: project_validate_failed)",
  "anyOf": [
    { "type": "null" },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["config_dir", "issues", "remote_warnings"],
      "properties": {
        "config_dir": { "type": "string" },
        "issues": { "type": "array", "items": { "type": "string" } },
        "remote_warnings": { "type": "array", "items": { "type": "string" } },
        "error": {
          "type": "object",
          "additionalProperties": true,
          "required": ["code", "message", "diagnostics_len"],
          "properties": {
            "code": { "type": "string" },
            "kind": {
              "type": "string",
              "enum": ["validation", "runtime", "io", "network", "config", "platform", "unknown"]
            },
            "message": { "type": "string" },
            "diagnostics_len": { "type": "integer", "minimum": 0 },
            "source_chain": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["message"],
                "properties": {
                  "message": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  ]
}
