{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://envr.dev/schemas/cli/error-kind-map.schema.json",
  "title": "cli error kind mapping contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["default", "kinds", "map"],
  "properties": {
    "default": {
      "type": "string",
      "minLength": 1
    },
    "kinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z_][a-z0-9_]*$"
      }
    },
    "map": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z_][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
